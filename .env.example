# Copy to .env

# Database dialect (ADR-050): sqlite (default) | postgres. Selects the Drizzle
# driver + schema; DATABASE_URL below is the connection for the chosen dialect.
DB_DIALECT=sqlite

# sqlite  → a file path (default). postgres → a postgres:// connection string, e.g.
#          postgres://user:pass@localhost:5432/baskets
DATABASE_URL=./data/baskets.db

BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:5173

# Comma-separated extra origins BetterAuth accepts for auth/callback requests.
# Leave empty for a single-origin local deploy; set when serving under a domain.
TRUSTED_ORIGINS=

# Local disk root for uploaded files (created on demand, gitignored).
# UPLOADS_DIR=./data/uploads

# Seed passwords (scripts/seed.ts). Set these in real deployments — the built-in
# fallbacks are dev-only. Must satisfy the 12-char minimum (ADR-048).
SEED_ADMIN_PASSWORD=
SEED_DEMO_PASSWORD=

# Auth hardening (ADR-048) is configured in src/lib/server/auth.ts:
#   - password minimum length: 12
#   - session lifetime: 14 days (refreshed at most once per active day)
#   - rate limiting: enabled automatically when NODE_ENV=production
