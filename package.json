{
	"name": "baskets",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Baskets — simple project management (projects, tasks, sub-tasks)",
	"scripts": {
		"dev": "vite dev",
		"icons:build": "node scripts/build-iconoir-sprite.mjs",
		"prebuild": "node scripts/build-iconoir-sprite.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"db:push": "drizzle-kit push",
		"db:seed": "node --env-file=.env scripts/seed.ts",
		"start": "node --env-file=.env server.js",
		"test": "vitest run",
		"test:unit": "vitest run tests/unit",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:watch": "vitest",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@fontsource/inter": "^5.2.8",
		"@tailwindcss/vite": "^4.3.0",
		"better-auth": "^1.3.0",
		"better-sqlite3": "^12.0.0",
		"daisyui": "^5.5.20",
		"drizzle-orm": "^0.45.2",
		"iconoir": "^7.11.0",
		"leaflet": "^1.9.4",
		"qrcode": "^1.5.4",
		"tailwindcss": "^4.3.0",
		"ws": "^8.21.0"
	},
	"overrides": {
		"esbuild": "0.25.12",
		"cookie": "^0.7.0",
		"form-data": "^4.0.6"
	},
	"devDependencies": {
		"@playwright/test": "^1.49.0",
		"@sveltejs/adapter-node": "^5.2.0",
		"@sveltejs/kit": "^2.20.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.6",
		"@types/better-sqlite3": "^7.6.13",
		"@types/leaflet": "^1.9.21",
		"@types/qrcode": "^1.5.5",
		"@types/ws": "^8.18.1",
		"@vitest/ui": "^3.0.0",
		"drizzle-kit": "^0.31.0",
		"jsdom": "^25.0.1",
		"svelte": "^5.28.0",
		"svelte-check": "^4.1.0",
		"typescript": "^5.8.0",
		"vite": "^6.3.0",
		"vitest": "^3.0.0"
	}
}
